{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "@pixel-office/client": ["../client/src/index.ts"],
      "@pixel-office/client/*": ["../client/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}